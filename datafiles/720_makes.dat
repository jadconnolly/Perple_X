       DQF(J/mol) = 0
kjL_q = 1 kspL - 1 qL
       DQF(J/mol) = 0
jdL_q = 1 abL - 1 qL
       DQF(J/mol) = 0
ekL_q = 1/2 eskL
       DQF(J/mol) = 0
